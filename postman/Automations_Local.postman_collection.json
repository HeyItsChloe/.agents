{
  "info": {
    "name": "Automations - Local",
    "description": "Trigger OpenHands automations via GitHub repository_dispatch.\n\n## Setup\n1. Import this collection into Postman\n2. Set GITHUB_TOKEN in the environment (GitHub Personal Access Token)\n3. Set ISSUE_NUMBER before triggering\n4. Click Send - that's it!\n\n## How It Works\n- Posts a repository_dispatch event to HeyItsChloe/.agents\n- The GitHub workflow extracts the issue info and triggers OpenHands\n- No polling, no extra steps - one click!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "GITHUB_TOKEN",
      "value": "",
      "description": "GitHub Personal Access Token with repo scope"
    },
    {
      "key": "TARGET_REPO",
      "value": "HeyItsChloe/.agents",
      "description": "Repository to dispatch to (usually HeyItsChloe/.agents)"
    },
    {
      "key": "ISSUE_NUMBER",
      "value": "42",
      "description": "GitHub issue number to process"
    },
    {
      "key": "REPO",
      "value": "11thandOrange/BusyBuddy_v2",
      "description": "Repository where the issue lives (owner/repo)"
    },
    {
      "key": "LABEL",
      "value": "ready-to-implement",
      "description": "Label that triggered this (e.g., ready-to-implement, complex-logic)"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{GITHUB_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "📤 Trigger OpenHands",
      "item": [
        {
          "name": "Trigger with Issue Number",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Successful dispatch', function() {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "console.log('✅ OpenHands triggered!');",
                  "console.log('Issue: ' + pm.variables.get('ISSUE_NUMBER'));",
                  "console.log('Repo: ' + pm.variables.get('REPO'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.github.v3+json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"event_type\": \"postman-webhook\",\n    \"client_payload\": {\n        \"issue\": {\n            \"number\": {{ISSUE_NUMBER}},\n            \"html_url\": \"https://github.com/{{REPO}}/issues/{{ISSUE_NUMBER}}\"\n        },\n        \"label\": {\n            \"name\": \"{{LABEL}}\"\n        },\n        \"repository\": \"{{REPO}}\"\n    }\n}"
            },
            "url": {
              "raw": "https://api.github.com/repos/{{TARGET_REPO}}/dispatches",
              "host": ["api", "github", "com"],
              "path": ["repos", "{{TARGET_REPO}}", "dispatches"]
            },
            "description": "Trigger OpenHands by posting a repository_dispatch event."
          }
        }
      ]
    },
