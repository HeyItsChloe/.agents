{
  "info": {
    "name": "Automations - Local",
    "description": "Trigger OpenHands via GitHub repository_dispatch. Set GITHUB_TOKEN in environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "GITHUB_TOKEN", "value": "", "description": "GitHub PAT with repo scope"},
    {"key": "ISSUE_NUMBER", "value": "42"},
    {"key": "REPO", "value": "11thandOrange/BusyBuddy_v2"}
  ],
